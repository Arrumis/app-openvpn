# OpenVPN Access Server の基本設定です。

# 公開ポートです。
# ADMIN_UI_PORT ... 管理画面
# HTTPS_PORT    ... クライアント UI
# VPN_UDP_PORT  ... VPN 本体
ADMIN_UI_PORT=943
HTTPS_PORT=9443
VPN_UDP_PORT=1194

# 永続化データの保存先です。
HOST_DATA_DIR=./data
OPENVPN_CONFIG_DIR=./data/config

# LinuxServer イメージ用の実行ユーザーです。
PUID=1000
PGID=1000

# コンテナ内タイムゾーンです。
TZ=Asia/Tokyo

# VPN が使うホスト側インターフェースです。
INTERFACE=eth0

# 管理者パスワードです。
OPENVPN_ADMIN_PASSWORD=change-me
